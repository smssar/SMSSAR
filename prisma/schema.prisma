generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SELLER
  ADMIN
}

enum UserStatus {
  ACTIVE
  PENDING
  FLAGGED
}

model City {
  id        String   @id @default(cuid())
  name      String   @unique
  name_en   String
  name_ar   String?
  name_fr   String?
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  neighborhoods Neighborhood[]
}

model Neighborhood {
  id        String   @id @default(cuid())
  name      String
  name_en   String
  name_ar   String?
  name_fr   String?
  slug      String?
  cityId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  city City @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@unique([cityId, name])
  @@unique([cityId, slug])
  @@index([cityId])
}

model PropertyType {
  id        String   @id @default(cuid())
  name      String   @unique
  name_en   String
  name_ar   String?
  name_fr   String?
  slug      String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
}

model Plan {
  id             String   @id
  title          String
  title_ar       String?
  title_fr       String?
  description    String
  description_ar String?
  description_fr String?
  price          Int
  listings       Int? // null = unlimited
  featured       Boolean
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  users User[]
}

model User {
  id           String     @id @default(cuid())
  name         String?
  email        String?    @unique
  emailVerified DateTime?
  passwordHash String?
  avatar       String?

  phone        String?
  city         String?
  bio          String?

  planId       String?

  role         UserRole   @default(USER)
  status       UserStatus @default(ACTIVE)

  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  plan         Plan?      @relation(fields: [planId], references: [id])

  properties   Property[]
  favorites    Favorite[]
  accounts     Account[]
  sessions     Session[]
}

model Account {
  id                 String  @id @default(cuid())

  userId             String
  provider           String
  providerAccountId  String

  access_token       String?
  refresh_token      String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Property {
  id             String   @id @default(cuid())
  title          String
  description    String?
  city           String
  neighborhood   String?
  area           Int?
  rooms          Int
  bathrooms      Int?
  price          Int
  propertyTypeId String?
  forSale        Boolean  @default(false)
  featured       Boolean  @default(false)
  priceType      String   @default("MONTHLY") // MONTHLY or DAILY
  imageUrl       String?
  videoUrl       String?
  sellerId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  propertyType PropertyType? @relation(fields: [propertyTypeId], references: [id], onDelete: Restrict)
  seller       User          @relation(fields: [sellerId], references: [id], onDelete: Cascade)
  media        Media[]
  favorites    Favorite[]

  @@index([propertyTypeId])
  @@index([city])
  @@index([neighborhood])
  @@index([featured])
}

model Favorite {
  id         String   @id @default(cuid())
  userId     String
  propertyId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([userId])
  @@index([propertyId])
}

model Media {
  id         String   @id @default(cuid())
  url        String
  publicId   String
  type       String   @default("image") // image or video
  propertyId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@index([propertyId])
}